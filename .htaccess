# =============================================================
# .htaccess — cache control for LiteSpeed / Apache
# Goal: HTML always fresh, versioned assets (?v=) cached long.
# =============================================================

# --- Do NOT let LiteSpeed cache the HTML pages ---
# This is what caused production to keep showing the old layout:
# the page itself was served from LiteSpeed cache. Keeping HTML
# uncached means a new ?v= on the CSS/JS link is always seen.
<IfModule LiteSpeed>
    RewriteEngine On
    # Disable LiteSpeed full-page cache for HTML documents
    RewriteRule .* - [E=Cache-Control:no-cache]
</IfModule>

<IfModule mod_headers.c>
    # HTML: never cache, always revalidate
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # Versioned static assets (css/js/images): safe to cache for a long time
    # because updating the file means bumping ?v=... in the HTML link.
    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|svg|webp|woff|woff2|ttf|eot|ico)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
</IfModule>

# --- Optional: gzip/deflate for faster delivery ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>
